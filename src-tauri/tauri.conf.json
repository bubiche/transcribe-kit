{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Transcribe Kit",
  "version": "1.0.0",
  "identifier": "dev.transcribekit.desktop",
  "build": {
    "beforeDevCommand": "trunk serve",
    "beforeBuildCommand": "trunk build --release",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Transcribe Kit",
        "width": 1100,
        "height": 760,
        "resizable": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/llama-server"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "frameworks": [
        "binaries/libllama.0.dylib",
        "binaries/libmtmd.0.dylib",
        "binaries/libggml.0.dylib",
        "binaries/libggml-base.0.dylib",
        "binaries/libggml-cpu.0.dylib",
        "binaries/libggml-blas.0.dylib",
        "binaries/libggml-metal.0.dylib",
        "binaries/libggml-rpc.0.dylib"
      ]
    }
  }
}
